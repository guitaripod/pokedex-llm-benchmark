{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pokedex-glm52-max",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
