{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pokedex-opus-4-8-low",
  "main": "worker/index.ts",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
